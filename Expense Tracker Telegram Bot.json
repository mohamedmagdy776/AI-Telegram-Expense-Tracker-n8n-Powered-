    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// ✅ نجيب التاريخ بتوقيت القاهرة بشكل صحيح\nconst cairoNow = new Date(\n  now.toLocaleString('en-US', { timeZone: 'Africa/Cairo' })\n);\n\n// ناخد اليوم بس بدون وقت\nconst todayDate = new Date(\n  cairoNow.getFullYear(),\n  cairoNow.getMonth(),\n  cairoNow.getDate()\n);\n\nconst formatDate = (date) => {\n  const day = String(date.getDate()).padStart(2, '0');\n  const month = String(date.getMonth() + 1).padStart(2, '0');\n  const year = date.getFullYear();\n  return `${year}-${month}-${day}`;\n};\n\nconst aiOutput = $('AI Agent').item.json.output;\nconst parsedOutput = typeof aiOutput === 'string' ? JSON.parse(aiOutput) : aiOutput;\n\nconst expense = parsedOutput.expense_details;\nconst originalQuery = (expense.original_query || '').toLowerCase();\n\nlet d = new Date(todayDate);\nlet finalDate;\n\nif (originalQuery.includes('day before yesterday')) {\n  d.setDate(d.getDate() - 2);\n  finalDate = formatDate(d);\n\n} else if (originalQuery.includes('yesterday')) {\n  d.setDate(d.getDate() - 1);\n  finalDate = formatDate(d);\n\n} else if (originalQuery.includes('today')) {\n  finalDate = formatDate(d);\n\n} else if (expense.date) {\n  const parsed = new Date(expense.date);\n  finalDate = !isNaN(parsed.getTime()) ? formatDate(parsed) : formatDate(d);\n\n} else {\n  finalDate = formatDate(d);\n}\n\nreturn [{\n  json: {\n    price: parseFloat((expense.price || '0').toString().replace(/[^0-9.]/g, '')) || 0,\n    item: expense.item,\n    place: expense.merchant,\n    date: finalDate,\n    currency: expense.currency || 'EGP',\n    number_of_items: expense.quantity || 1\n  }\n}];\n"
      },
